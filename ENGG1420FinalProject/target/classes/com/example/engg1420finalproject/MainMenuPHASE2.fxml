<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.engg1420finalproject.MainMenuController">
   <children>
      <StackPane prefHeight="150.0" prefWidth="200.0">
         <children>
            <BorderPane prefHeight="400.0" prefWidth="200.0" translateY="50.0">
               <center>
                  <VBox fx:id="drawer" prefHeight="200.0" prefWidth="200.0" translateX="-200.0" BorderPane.alignment="CENTER">
                     <children>
                        <Accordion>
                          <panes>
                            <TitledPane animated="false" text="User">
                              <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                              </content>
                            </TitledPane>
                            <TitledPane animated="false" text="Event">
                              <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                              </content>
                            </TitledPane>
                            <TitledPane animated="false" text="Booking">
                              <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                              </content>
                            </TitledPane>
                              <TitledPane animated="false" layoutX="10.0" layoutY="60.0" text="WaitList">
                                 <content>
                                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                                 </content>
                              </TitledPane>
                          </panes>
                        </Accordion>
                     </children>
                  </VBox>
               </center>
            </BorderPane>
            <Button mnemonicParsing="false" onAction="#openSideMenu" rotate="90.0" text="|||" translateX="-80.0" translateY="-50.0" />
         </children>
      </StackPane>
   </children>
</AnchorPane>
