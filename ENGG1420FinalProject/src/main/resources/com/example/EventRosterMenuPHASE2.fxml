<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.EventsPageController">
   <children>
      <ScrollPane layoutX="220.0" layoutY="49.0" prefHeight="154.0" prefWidth="185.0">
         <content>
            <VBox fx:id="confirmedBookingsContainer" prefHeight="154.0" prefWidth="185.0" />
         </content></ScrollPane>
      <Button layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#backToMenu" text="Back">
         <font>
            <Font name="Baskerville Old Face" size="12.0" />
         </font>
      </Button>
      <ScrollPane layoutX="410.0" layoutY="49.0" prefHeight="154.0" prefWidth="185.0">
         <content>
            <VBox fx:id="waitlistBookingsContainer" prefHeight="154.0" prefWidth="185.0" />
         </content>
      </ScrollPane>
      <Label layoutX="451.0" layoutY="14.0" text="Waitlisted">
         <font>
            <Font name="Baskerville Old Face" size="20.0" />
         </font>
      </Label>
      <Label layoutX="261.0" layoutY="14.0" text="Confirmed">
         <font>
            <Font name="Baskerville Old Face" size="20.0" />
         </font>
      </Label>
      <ScrollPane layoutX="55.0" layoutY="49.0" prefHeight="240.0" prefWidth="156.0">
         <content>
            <VBox fx:id="eventsContainer" prefHeight="240.0" prefWidth="156.0" />
         </content>
      </ScrollPane>
      <TextField fx:id="eventID" layoutX="55.0" layoutY="14.0" prefHeight="26.0" prefWidth="101.0" promptText="Event ID" />
      <fx:include fx:id="menuPanel" source="MenuPanel.fxml" />
      <Button layoutX="167.0" layoutY="15.0" mnemonicParsing="false" onAction="#searchByID" text="Search">
         <font>
            <Font name="Baskerville Old Face" size="14.0" />
         </font>
      </Button>
      <Pane layoutX="300.0" layoutY="252.0" prefHeight="139.0" prefWidth="201.0">
         <children>
            <VBox fx:id="selectedEventContainer" prefHeight="139.0" prefWidth="202.0" />
         </children>
      </Pane>
      <Label layoutX="327.0" layoutY="221.0" text="Event Currently Selected">
         <font>
            <Font name="Baskerville Old Face" size="15.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
