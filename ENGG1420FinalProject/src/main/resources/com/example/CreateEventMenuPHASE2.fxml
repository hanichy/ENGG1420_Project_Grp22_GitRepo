<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.EventsPageConroller">
   <children>
      <Button layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#backToMenu" text="Back" />
      <Button layoutX="305.0" layoutY="286.0" mnemonicParsing="false" text="Create Event!">
         <font>
            <Font name="Baskerville Old Face" size="40.0" />
         </font></Button>
      <TextField fx:id="eventTitle" layoutX="402.0" layoutY="88.0" promptText="Event Title" />
      <TextField fx:id="eventLocation" layoutX="402.0" layoutY="124.0" promptText="Event Location" />
      <DatePicker fx:id="eventDate" layoutX="402.0" layoutY="160.0" promptText="Event Date" />
      <TextField fx:id="eventCapacity" layoutX="402.0" layoutY="196.0" promptText="Event Capacity" />
      <TextField fx:id="eventSpeaker" layoutX="189.0" layoutY="49.0" opacity="0.0" prefHeight="26.0" prefWidth="95.0" promptText="Speaker Name" />
      <TextField fx:id="eventTopic" layoutX="293.0" layoutY="50.0" opacity="0.0" prefWidth="95.0" promptText="Topic" />
      <TextField fx:id="eventAgeRestriction" layoutX="396.0" layoutY="50.0" opacity="0.0" prefWidth="95.0" promptText="Age Restriction" />
      <Button layoutX="207.0" layoutY="14.0" mnemonicParsing="false" text="Seminar" />
      <Button layoutX="305.0" layoutY="14.0" mnemonicParsing="false" text="Workshop" />
      <Button layoutX="415.0" layoutY="14.0" mnemonicParsing="false" text="Concert" />
      <ImageView fitHeight="150.0" fitWidth="200.0" layoutX="199.0" layoutY="78.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@2025_New_Gryphon_Logo.png" />
         </image>
      </ImageView>
      <StackPane prefHeight="150.0" prefWidth="200.0">
         <children>
            <fx:include fx:id="menuPanel" source="MenuPanel.fxml" />
         </children>
      </StackPane>
   </children>
</AnchorPane>
