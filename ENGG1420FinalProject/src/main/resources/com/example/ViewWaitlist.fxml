<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.WaitlistPageController">
    <children>
        <Label alignment="CENTER" layoutX="145.0" layoutY="20.0" prefHeight="54.0" prefWidth="285.0" text="Waitlisted users">
            <font>
                <Font name="Baskerville Old Face" size="36.0" />
            </font>
        </Label>

        <TextField fx:id="userIDField" layoutX="55.0" layoutY="97.0" prefHeight="26.0" prefWidth="180.0" promptText="Enter User ID" />
        <Button layoutX="245.0" layoutY="97.0" mnemonicParsing="false" onAction="#searchWaitlistByUser" text="View User Waitlist">
            <font>
                <Font name="Baskerville Old Face" size="14.0" />
            </font>
        </Button>

        <ScrollPane layoutX="55.0" layoutY="139.0" prefHeight="200.0" prefWidth="490.0">
            <content>
                <VBox fx:id="waitlistBookingsContainer" prefWidth="475.0" spacing="10.0" style="-fx-padding: 10;" />
            </content>
        </ScrollPane>

        <Label fx:id="statusLabel" layoutX="55.0" layoutY="330.0" textFill="#c90000">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>

        <Button layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#backToMenu" text="Back">
            <font>
                <Font name="Baskerville Old Face" size="12.0" />
            </font>
        </Button>

        <fx:include fx:id="menuPanel" source="MenuPanel.fxml" />
    </children>
</AnchorPane>
