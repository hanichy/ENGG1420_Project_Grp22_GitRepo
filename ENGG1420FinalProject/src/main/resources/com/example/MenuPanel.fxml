<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.MainMenuController">
   <children>
      <StackPane prefHeight="150.0" prefWidth="200.0" translateY="50.0">
         <children>
            <BorderPane prefHeight="200.0" prefWidth="200.0">
               <center>
                  <VBox fx:id="drawer" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                     <children>
                        <Accordion>
                          <panes>
                            <TitledPane animated="false" text="User">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="Create User" />
                                          <Button mnemonicParsing="false" text="View User Details" />
                                          <Button mnemonicParsing="false" text="List All Users" />
                                       </children></VBox>
                                 </content>
                            </TitledPane>
                            <TitledPane animated="false" text="Events">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" onAction="#switchToCreateEvent" text="Create Event" />
                                          <Button mnemonicParsing="false" onAction="#switchToUpdateEvent" text="Update Event Information" />
                                          <Button layoutX="20.0" layoutY="45.0" mnemonicParsing="false" onAction="#switchToCancelEvent" text="Cancel Event" />
                                          <Button layoutX="20.0" layoutY="71.0" mnemonicParsing="false" onAction="#switchToEventRoster" text="View Event Roster" />
                                          <Button layoutX="20.0" layoutY="96.0" mnemonicParsing="false" onAction="#switchToEventSearch" text="Search Event By Title" />
                                       </children></VBox>
                                 </content>
                            </TitledPane>
                            <TitledPane animated="false" text="Booking">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="Book an Event" />
                                          <Button layoutX="20.0" layoutY="20.0" mnemonicParsing="false" text="Cancel a Booking" />
                                       </children></VBox>
                                 </content>
                            </TitledPane>
                              <TitledPane animated="false" layoutX="10.0" layoutY="61.0" text="WaitList">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="View Event WaitList" />
                                          <Button layoutX="20.0" layoutY="20.0" mnemonicParsing="false" text="Remove a WaitList Booking" />
                                       </children></VBox>
                                 </content>
                              </TitledPane>
                          </panes>
                        </Accordion>
                     </children>
                  </VBox>
               </center>
            </BorderPane>
         </children>
      </StackPane>
      <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#openMenu" rotate="90.0" text="|||" />
   </children>
</AnchorPane>
