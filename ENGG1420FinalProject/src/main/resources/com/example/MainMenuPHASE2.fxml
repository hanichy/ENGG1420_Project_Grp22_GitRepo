<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.MainMenuController">
   <children>
      <StackPane prefHeight="150.0" prefWidth="200.0">
         <children>
            <BorderPane prefHeight="400.0" prefWidth="200.0" translateY="50.0">
               <center>
                  <VBox fx:id="drawer" prefHeight="145.0" prefWidth="200.0" spacing="15.0" BorderPane.alignment="CENTER">
                     <children>
                        <Accordion>
                          <panes>
                            <TitledPane animated="false" minWidth="-Infinity" prefWidth="200.0" text="User">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="Create User" />
                                          <Button mnemonicParsing="false" text="View User Details" />
                                          <Button mnemonicParsing="false" text="List All Users" />
                                       </children>
                                    </VBox>
                                 </content>
                            </TitledPane>
                            <TitledPane animated="false" prefWidth="200.0" text="Event">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" onAction="#switchToCreateEvent" text="Create Event" />
                                          <Button mnemonicParsing="false" text="Update Event Information" />
                                          <Button mnemonicParsing="false" text="Cancel Event" />
                                          <Button mnemonicParsing="false" text="View Event Roster" />
                                          <Button mnemonicParsing="false" text="Search Events By Title" />
                                       </children>
                                    </VBox>
                                 </content>
                            </TitledPane>
                            <TitledPane animated="false" text="Booking">
                                 <content>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="Book an Event" />
                                          <Button mnemonicParsing="false" text="Cancel a Booking" />
                                       </children>
                                    </VBox>
                                 </content>
                            </TitledPane>
                              <TitledPane animated="false" layoutX="10.0" layoutY="60.0" prefHeight="134.0" prefWidth="200.0" text="WaitList">
                                 <content>
                                    <VBox prefHeight="92.0" prefWidth="198.0">
                                       <children>
                                          <Button mnemonicParsing="false" text="View Event Waitlist" />
                                          <Button mnemonicParsing="false" text="Remove a Waitlist Booking" />
                                       </children>
                                            </VBox>
                                 </content>
                              </TitledPane>
                          </panes>
                        </Accordion>
                     </children></VBox>
               </center>
            </BorderPane>
         </children>
      </StackPane>
      <Button mnemonicParsing="false" onAction="#openMenu" rotate="90.0" text="|||" translateX="10.0" translateY="10.0" />
      <ImageView fitHeight="269.0" fitWidth="334.0" layoutX="230.0" layoutY="57.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@2025_New_Gryphon_Logo.png" />
         </image>
      </ImageView>
      <Label layoutX="36.0" layoutY="308.0" prefHeight="60.0" prefWidth="528.0" text="Guelph Campus Booking System">
         <font>
            <Font name="Baskerville Old Face" size="39.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
