<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookingsys.CreateUserController">

   <children>

      <Label layoutX="200.0" layoutY="20.0" text="Create User" />

      <TextField fx:id="userIdField" layoutX="150.0" layoutY="80.0" prefWidth="300.0" promptText="User ID" />

      <TextField fx:id="nameField" layoutX="150.0" layoutY="130.0" prefWidth="300.0" promptText="Name" />

      <TextField fx:id="emailField" layoutX="150.0" layoutY="180.0" prefWidth="300.0" promptText="Email" />

      <ComboBox fx:id="userTypeBox" layoutX="150.0" layoutY="230.0" prefWidth="300.0" />

      <TextField fx:id="extraField" layoutX="150.0" layoutY="280.0" prefWidth="300.0" promptText="Department / Student ID (if needed)" />

      <Button layoutX="247.0" layoutY="312.0" onAction="#handleCreateUser" text="Create User" />

      <Button layoutX="20.0" layoutY="350.0" onAction="#switchToMainMenu" text="Return" />

   </children>
</AnchorPane>
