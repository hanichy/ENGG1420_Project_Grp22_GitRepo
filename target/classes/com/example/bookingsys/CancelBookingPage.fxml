<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookingsys.BookingPageController">
    <children>
        <TextField fx:id="eventID" layoutX="14.0" layoutY="37.0" promptText="Enter Event ID" />
        <Button layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#backToMenuE" text="Back to Main Menu" />
        <Button layoutX="183.0" layoutY="37.0" mnemonicParsing="false" onAction="#search" text="Search" />
        <Button layoutX="490.0" layoutY="21.0" mnemonicParsing="false" onAction="#displayList" text="Refresh" />
        <ScrollPane layoutX="14.0" layoutY="81.0" prefHeight="200.0" prefWidth="200.0">
            <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
                    <children>
                        <VBox fx:id="container" prefHeight="200.0" prefWidth="200.0" />
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
        <Button layoutX="341.0" layoutY="156.0" mnemonicParsing="false" onAction="#cancelBookingButton" text="CANCEL BOOKING">
            <font>
                <Font size="29.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
