<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookingsys.EventsPageController">
    <children>
        <Button layoutX="14.0" layoutY="346.0" mnemonicParsing="false" onAction="#backToMenuE" text="Testing Back to Menu" />
        <TextField fx:id="eventTitle" layoutX="14.0" layoutY="48.0" promptText="Title" />
        <TextField fx:id="eventDate" layoutX="14.0" layoutY="90.0" promptText="Date" />
        <TextField fx:id="eventLocation" layoutX="14.0" layoutY="138.0" promptText="Location" />
        <TextField fx:id="eventCapacity" layoutX="14.0" layoutY="187.0" promptText="Capacity" />
        <Button layoutX="300.0" layoutY="48.0" mnemonicParsing="false" onAction="#workShopButton" text="Workshop" />
        <Button layoutX="300.0" layoutY="103.0" mnemonicParsing="false" onAction="#seminarButton" text="Seminar" />
        <Button layoutX="300.0" layoutY="174.0" mnemonicParsing="false" onAction="#concertButton" text="Concert" />
        <TextField fx:id="eventTopic" layoutX="373.0" layoutY="48.0" opacity="0.0" promptText="Topic" />
        <TextField fx:id="eventSpeaker" layoutX="373.0" layoutY="103.0" opacity="0.0" promptText="Speaker Name" />
        <TextField fx:id="eventAgeRestriction" layoutX="373.0" layoutY="174.0" opacity="0.0" promptText="Age Restriction" />
        <Button layoutX="212.0" layoutY="227.0" mnemonicParsing="false" onAction="#handleCreateEvent" text="Create Event">
            <font>
                <Font size="49.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
