<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--im using gridpane for my container because it is flexible with its layouts-->
<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
          prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.bookingsys.HelloController">
<!--the controller file is specified in thje line fx:controller="com.example.bookingsys.HelloController.
note: you can get the file reference like i did here in intellij by right clicking on a file, click copy path/reference, click copy reference.-->
<!--gridpane is divided into rows and columns and you place objects into the rows and columns-->
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
    </rowConstraints>
<!--the onaction=#... thing basically says that when the button is interacted with, call the method with this name in the controller file (mentioned above)-->
    <Button mnemonicParsing="false" onAction="#handleCreateUser" text="Create a user" GridPane.halignment="RIGHT"
            GridPane.rowIndex="1"/>
    <Button mnemonicParsing="false" onAction="#handleCreateEvent" text="Create a event" GridPane.columnIndex="1"
            GridPane.halignment="LEFT" GridPane.rowIndex="1"/>
    <Label fx:id="statusLabel" text="waiting..." GridPane.halignment="RIGHT" GridPane.rowIndex="2"
           GridPane.valignment="TOP"/>
</GridPane>
